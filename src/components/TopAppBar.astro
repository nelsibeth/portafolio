---
// src/components/TopAppBar.astro
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove first /
---

<nav class="fixed top-0 w-full z-50 bg-[#00101d]/60 backdrop-blur-xl transition-all left-0 right-0">
  <div class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto">
    <div class="text-xl font-bold tracking-tighter text-sky-400 font-headline">Nelsibeth Oliva</div>
    <div class="hidden md:flex items-center gap-8 font-headline text-sm tracking-tight">
      <a class={`transition-colors ${currentPath === '' ? 'text-sky-400 border-b-2 border-sky-400 pb-1' : 'text-slate-400 hover:text-sky-300'}`} href="/">Experiencia</a>
      <a class={`transition-colors ${currentPath === 'projects' ? 'text-sky-400 border-b-2 border-sky-400 pb-1' : 'text-slate-400 hover:text-sky-300'}`} href="/projects">Proyectos</a>
      <a class={`transition-colors text-slate-400 hover:text-sky-300`} href="#">Stack</a>
      <a class={`transition-colors ${currentPath === 'contact' ? 'text-sky-400 border-b-2 border-sky-400 pb-1' : 'text-slate-400 hover:text-sky-300'}`} href="/contact">Contacto</a>
    </div>
    <button class="backdrop-blur-xl bg-primary/10 border border-primary/20 text-on-surface font-headline font-bold px-6 py-2 rounded-xl hover:bg-primary/20 hover:border-primary/40 hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(59,130,246,0.4)] active:scale-95 transition-all text-sm group">
      Descargar CV
    </button>
  </div>
</nav>
