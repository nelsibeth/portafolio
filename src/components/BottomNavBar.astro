---
// src/components/BottomNavBar.astro
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1);
---
<div class="md:hidden fixed bottom-0 left-0 right-0 bg-[#00101d]/90 backdrop-blur-lg px-6 py-3 flex justify-between items-center z-50 border-t border-sky-900/15">
    <a href="/" class={`flex flex-col items-center gap-1 ${currentPath === '' ? 'text-primary' : 'text-slate-400'}`}>
        <span class="material-symbols-outlined" translate="no" data-icon="work">work</span>
        <span class="text-[10px] font-label">Experiencia</span>
    </a>
    <a href="/projects" class={`flex flex-col items-center gap-1 ${currentPath === 'projects' ? 'text-primary' : 'text-slate-400'}`}>
        <span class="material-symbols-outlined" translate="no" data-icon="terminal">terminal</span>
        <span class="text-[10px] font-label">Proyectos</span>
    </a>
    <a href="#" class={`flex flex-col items-center gap-1 text-slate-400`}>
        <span class="material-symbols-outlined" translate="no" data-icon="layers">layers</span>
        <span class="text-[10px] font-label">Stack</span>
    </a>
    <a href="/contact" class={`flex flex-col items-center gap-1 ${currentPath === 'contact' ? 'text-primary' : 'text-slate-400'}`}>
        <span class="material-symbols-outlined" translate="no" data-icon="mail">mail</span>
        <span class="text-[10px] font-label">Contacto</span>
    </a>
</div>
