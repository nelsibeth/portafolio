---
// src/components/SideNavBar.astro
// Active state checking logic
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1);
---
<aside class="hidden lg:flex flex-col h-screen sticky top-0 fixed left-0 w-64 border-r border-sky-900/15 bg-[#001524] shadow-[40px_0_60px_rgba(209,232,255,0.06)] z-40 overflow-y-auto pt-20">
    <div class="p-8">
        <div class="w-16 h-16 rounded-full overflow-hidden mb-4 ring-2 ring-primary/20">
            <img class="w-full h-full object-cover" alt="Nelsibeth Oliva - Pixel Art" src="/profile.png"/>
        </div>
        <h2 class="text-lg font-black text-sky-400 font-headline">Nelsibeth Oliva</h2>
        <p class="text-sm text-slate-400 font-label">Odoo Developer</p>
    </div>
    
    <nav class="flex-1 space-y-2">
        <a href="/" class={`flex items-center gap-3 px-4 py-3 rounded-r-full group transition-all ${currentPath === '' ? 'bg-sky-400/10 text-sky-400 font-bold' : 'text-slate-400 hover:bg-[#002237]'}`}>
            <span class={`material-symbols-outlined ${currentPath === '' ? 'text-primary' : ''}`} translate="no" data-icon="work">work</span>
            <span class="font-headline">Experiencia</span>
        </a>
        <a href="/projects" class={`flex items-center gap-3 px-4 py-3 rounded-r-full group transition-all ${currentPath === 'projects' ? 'bg-sky-400/10 text-sky-400 font-bold' : 'text-slate-400 hover:bg-[#002237]'}`}>
            <span class={`material-symbols-outlined ${currentPath === 'projects' ? 'text-primary' : ''}`} translate="no" data-icon="terminal">terminal</span>
            <span class="font-headline">Proyectos</span>
        </a>
        <a href="#" class="flex items-center gap-3 px-4 py-3 text-slate-400 hover:bg-[#002237] transition-all rounded-r-full group">
            <span class="material-symbols-outlined" translate="no" data-icon="layers">layers</span>
            <span class="font-headline">Stack</span>
        </a>
        <a href="/contact" class={`flex items-center gap-3 px-4 py-3 rounded-r-full group transition-all ${currentPath === 'contact' ? 'bg-sky-400/10 text-sky-400 font-bold' : 'text-slate-400 hover:bg-[#002237]'}`}>
            <span class={`material-symbols-outlined ${currentPath === 'contact' ? 'text-primary' : ''}`} translate="no" data-icon="mail">mail</span>
            <span class="font-headline">Contacto</span>
        </a>
    </nav>
    <div class="p-8 mt-auto">
        <button class="w-full py-3 primary-gradient text-on-primary font-bold rounded-xl text-sm transition-all hover:scale-[0.98] font-headline">
            Contrátame
        </button>
    </div>
</aside>
