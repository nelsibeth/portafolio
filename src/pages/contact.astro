---
import Layout from '../layouts/Layout.astro';
import TopAppBar from '../components/TopAppBar.astro';
import SideNavBar from '../components/SideNavBar.astro';
import BottomNavBar from '../components/BottomNavBar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact | Nelsibeth Oliva - Odoo Developer">
    <TopAppBar />
    
    <div class="flex min-h-screen pt-20">
        <SideNavBar />
        
        <main class="flex-1 px-6 md:px-12 py-12 max-w-7xl mx-auto grid grid-cols-1 xl:grid-cols-12 gap-12 items-start">
            <!-- Left Column: Editorial Content -->
            <div class="xl:col-span-5 space-y-12">
                <section>
                    <span class="text-primary font-label text-xs tracking-[0.2em] uppercase mb-4 block">Final Transmission</span>
                    <h1 class="text-5xl md:text-7xl font-headline font-bold leading-none tracking-tighter mb-8">
                        Let's Build the <span class="text-gradient">Next Chapter.</span>
                    </h1>
                    <p class="text-on-surface-variant text-lg leading-relaxed max-w-md font-body">
                        Whether you're looking for an Odoo specialist to scale your ecosystem or a technical architect for a complex ERP migration, I'm ready to connect.
                    </p>
                </section>

                <!-- Social Connect Bento -->
                <div class="grid grid-cols-2 gap-4">
                    <a href="#" class="group p-6 bg-surface-container rounded-xl border-outline-variant/15 hover:bg-surface-container-high transition-all">
                        <span class="material-symbols-outlined text-primary mb-4" data-icon="link">link</span>
                        <h3 class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors">LinkedIn</h3>
                        <p class="text-xs text-on-surface-variant font-label mt-1">Professional Network</p>
                    </a>
                    
                    <a href="#" class="group p-6 bg-surface-container rounded-xl border-outline-variant/15 hover:bg-surface-container-high transition-all">
                        <span class="material-symbols-outlined text-primary mb-4" data-icon="terminal">terminal</span>
                        <h3 class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors">GitHub</h3>
                        <p class="text-xs text-on-surface-variant font-label mt-1">Code Repository</p>
                    </a>
                </div>

                <!-- Quick Info -->
                <div class="space-y-6 pt-6">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary" data-icon="mail">mail</span>
                        </div>
                        <div>
                            <p class="text-xs text-on-surface-variant font-label uppercase tracking-widest">Email Address</p>
                            <p class="font-headline font-medium text-on-surface">hello@nelsibeth.dev</p>
                        </div>
                    </div>
                    
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary" data-icon="location_on">location_on</span>
                        </div>
                        <div>
                            <p class="text-xs text-on-surface-variant font-label uppercase tracking-widest">Location</p>
                            <p class="font-headline font-medium text-on-surface">Remote / Global</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Contact Form -->
            <div class="xl:col-span-7 w-full">
                <div class="glass-panel p-8 md:p-12 rounded-[2rem] border border-outline-variant/10 shadow-[40px_0_60px_rgba(209,232,255,0.06)]">
                    <form class="space-y-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-2">
                                <label class="text-xs font-label uppercase tracking-widest text-on-surface-variant ml-1">Full Name</label>
                                <input type="text" placeholder="Jane Doe" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary text-on-surface placeholder:text-slate-600 transition-all font-body">
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-label uppercase tracking-widest text-on-surface-variant ml-1">Email Address</label>
                                <input type="email" placeholder="jane@company.com" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary text-on-surface placeholder:text-slate-600 transition-all font-body">
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="text-xs font-label uppercase tracking-widest text-on-surface-variant ml-1">Project Type</label>
                            <div class="flex flex-wrap gap-3">
                                <button type="button" class="px-5 py-2 rounded-full bg-primary/10 border border-primary/20 text-primary text-sm font-medium font-body">Odoo Implementation</button>
                                <button type="button" class="px-5 py-2 rounded-full bg-surface-container-high text-on-surface-variant text-sm font-medium hover:bg-surface-bright transition-colors font-body">Migration</button>
                                <button type="button" class="px-5 py-2 rounded-full bg-surface-container-high text-on-surface-variant text-sm font-medium hover:bg-surface-bright transition-colors font-body">Consulting</button>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="text-xs font-label uppercase tracking-widest text-on-surface-variant ml-1">Message</label>
                            <textarea rows="5" placeholder="Tell me about your project goals..." class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary text-on-surface placeholder:text-slate-600 transition-all resize-none font-body"></textarea>
                        </div>

                        <button class="w-full primary-gradient text-on-primary font-headline font-bold py-5 rounded-xl text-lg flex items-center justify-center gap-2 group hover:shadow-[0_0_30px_rgba(59,191,250,0.3)] transition-all">
                            Initiate Connection
                            <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform" data-icon="arrow_forward">arrow_forward</span>
                        </button>
                    </form>
                </div>

                <!-- Aesthetic Image Support -->
                <div class="mt-8 relative h-48 w-full rounded-[2rem] overflow-hidden group">
                    <img 
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuBcZKPpOUFBu8yJLeIaBu_LsYzR_RxJL4lx5pcFED6zsUu3V0rq_8owgX8_IRRS6mrLr9AR0GkybwMJniw5L9no_ByJVeZcv2WTURLTfqqr4bb6rI91fLBGk0ZRTMdR102HnzNPH9AqDHVDHAnTgWlGkEnsVEhRjwRAb6oJSJh-IxS2MoYNCf2234PGhOQtrJs1H4tNuXQF4AOctL5vLGTctsXVeyv6VHb1UvyhcOz20oB2ZPEpc-DM84i3kCCvv4SpKy71BjIRuYAm" 
                        alt="Global connectivity abstract" 
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
                        data-alt="Abstract digital visualization of global network connections with flowing cyan data streams on a deep navy background in a 2026 tech aesthetic"
                    >
                    <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent"></div>
                    <div class="absolute bottom-6 left-8 flex items-center gap-3">
                        <div class="w-2 h-2 rounded-full bg-primary animate-pulse"></div>
                        <span class="text-xs font-label uppercase tracking-widest text-on-surface">Currently accepting new projects for Q3 2026</span>
                    </div>
                </div>
            </div>
        </main>
    </div>
    
    <Footer />
    <BottomNavBar />
</Layout>
