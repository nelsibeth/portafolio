---
import Layout from '../layouts/Layout.astro';
import TopAppBar from '../components/TopAppBar.astro';
import SideNavBar from '../components/SideNavBar.astro';
import BottomNavBar from '../components/BottomNavBar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contacto | Nelsibeth Oliva - Desarrollador Odoo">
    <TopAppBar />
    
    <div class="flex min-h-screen pt-20">
        <SideNavBar />
        
        <main class="flex-1 px-6 md:px-12 py-12 max-w-7xl mx-auto grid grid-cols-1 xl:grid-cols-12 gap-12 items-start">
            <!-- Left Column: Editorial Content -->
            <div class="xl:col-span-5 space-y-12">
                <section>
                    <span class="text-primary font-label text-xs tracking-[0.2em] uppercase mb-4 block">Transmisión Final</span>
                    <h1 class="text-5xl md:text-7xl font-headline font-bold leading-none tracking-tighter mb-8">
                        Construyamos el <span class="text-gradient">Próximo Capítulo.</span>
                    </h1>
                    <p class="text-on-surface-variant text-lg leading-relaxed max-w-md font-body">
                        Ya sea que estés buscando un especialista en Odoo para escalar tu ecosistema o un arquitecto técnico para una migración compleja de ERP, estoy listo para conectarme.
                    </p>
                </section>

                <!-- Social Connect Bento -->
                <div class="grid grid-cols-2 gap-4">
                    <a href="#" class="group p-6 bg-surface-container rounded-xl border-outline-variant/15 hover:bg-surface-container-high transition-all">
                        <span class="material-symbols-outlined text-primary mb-4" translate="no" data-icon="link">link</span>
                        <h3 class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors">LinkedIn</h3>
                        <p class="text-xs text-on-surface-variant font-label mt-1">Red Profesional</p>
                    </a>
                    
                    <a href="#" class="group p-6 bg-surface-container rounded-xl border-outline-variant/15 hover:bg-surface-container-high transition-all">
                        <span class="material-symbols-outlined text-primary mb-4" translate="no" data-icon="terminal">terminal</span>
                        <h3 class="font-headline font-bold text-on-surface group-hover:text-primary transition-colors">GitHub</h3>
                        <p class="text-xs text-on-surface-variant font-label mt-1">Repositorio de Código</p>
                    </a>
                </div>

                <!-- Quick Info -->
                <div class="space-y-6 pt-6">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary" translate="no" data-icon="mail">mail</span>
                        </div>
                        <div>
                            <p class="text-xs text-on-surface-variant font-label uppercase tracking-widest">Correo Electrónico</p>
                            <p class="font-headline font-medium text-on-surface">hello@nelsibeth.dev</p>
                        </div>
                    </div>
                    
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary" translate="no" data-icon="location_on">location_on</span>
                        </div>
                        <div>
                            <p class="text-xs text-on-surface-variant font-label uppercase tracking-widest">Ubicación</p>
                            <p class="font-headline font-medium text-on-surface">Remoto / Global</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Contact Form -->
            <div class="xl:col-span-7 w-full">
                <div class="glass-panel p-8 md:p-12 rounded-[2rem] border border-outline-variant/10 shadow-[40px_0_60px_rgba(209,232,255,0.06)]">
                    <form class="space-y-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-2">
                                <label class="text-xs font-label uppercase tracking-widest text-on-surface-variant ml-1">Nombre Completo</label>
                                <input type="text" placeholder="Juana De Arco" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary text-on-surface placeholder:text-slate-600 transition-all font-body">
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-label uppercase tracking-widest text-on-surface-variant ml-1">Correo Electrónico</label>
                                <input type="email" placeholder="juana@empresa.com" class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary text-on-surface placeholder:text-slate-600 transition-all font-body">
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="text-xs font-label uppercase tracking-widest text-on-surface-variant ml-1">Tipo de Proyecto</label>
                            <div class="flex flex-wrap gap-3">
                                <button type="button" class="backdrop-blur-md px-5 py-2 rounded-full bg-white/5 border border-white/10 text-on-surface-variant text-sm font-medium transition-all hover:bg-white/10 hover:-translate-y-0.5 active:scale-95 font-body">Implementación Odoo</button>
                                <button type="button" class="backdrop-blur-md px-5 py-2 rounded-full bg-white/5 border border-white/10 text-on-surface-variant text-sm font-medium hover:bg-white/10 transition-all hover:-translate-y-0.5 active:scale-95 font-body">Migración</button>
                                <button type="button" class="backdrop-blur-md px-5 py-2 rounded-full bg-white/5 border border-white/10 text-on-surface-variant text-sm font-medium hover:bg-white/10 transition-all hover:-translate-y-0.5 active:scale-95 font-body">Consultoría</button>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="text-xs font-label uppercase tracking-widest text-on-surface-variant ml-1">Mensaje</label>
                            <textarea rows="5" placeholder="Cuéntame sobre los objetivos de tu proyecto..." class="w-full bg-surface-container-lowest border-none rounded-xl p-4 focus:ring-2 focus:ring-primary text-on-surface placeholder:text-slate-600 transition-all resize-none font-body"></textarea>
                        </div>

                        <button class="w-full backdrop-blur-xl bg-primary/10 border border-primary/20 text-on-surface font-headline font-bold py-5 rounded-xl text-lg flex items-center justify-center gap-2 group hover:bg-primary/20 hover:border-primary/40 hover:shadow-[0_0_25px_rgba(59,130,246,0.4)] hover:-translate-y-1 active:scale-95 transition-all">
                            Iniciar Conexión
                            <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform" translate="no" data-icon="arrow_forward">arrow_forward</span>
                        </button>
                    </form>
                </div>

                <!-- Aesthetic Image Support -->
                <div class="mt-8 relative h-48 w-full rounded-[2rem] overflow-hidden group">
                    <img 
                        src="/profile.png" 
                        alt="Nelsibeth Oliva - Pixel Art" 
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
                    >
                    <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent"></div>
                    <div class="absolute bottom-6 left-8 flex items-center gap-3">
                        <div class="w-2 h-2 rounded-full bg-primary animate-pulse"></div>
                        <span class="text-xs font-label uppercase tracking-widest text-on-surface">Actualmente aceptando nuevos proyectos para el Q3 2026</span>
                    </div>
                </div>
            </div>
        </main>
    </div>
    
    <Footer />
    <BottomNavBar />
</Layout>
